# Backend environment (Render / local)
# Comma-separated list of allowed frontend origins for CORS:
# - local Vite dev server
# - your Vercel production domain
ALLOWED_ORIGINS=http://localhost:5173,https://stacklens-purple.vercel.app

# Optional: increases GitHub API rate limits (keep secret, never expose to frontend)
# GITHUB_TOKEN=ghp_...

# Optional: server port (Render sets PORT automatically)
# PORT=4000

